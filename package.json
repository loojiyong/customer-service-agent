{
  "name": "whatsapp-ai-webhook",
  "version": "1.0.0",
  "description": "WhatsApp Business message logging webhook for AWS Lambda",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "serverless offline",
    "deploy": "serverless deploy --region ap-southeast-1",
    "invoke": "serverless invoke --function whatsappWebhook --region ap-southeast-1",
    "logs": "serverless logs --function whatsappWebhook --region ap-southeast-1",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "whatsapp",
    "webhook",
    "aws-lambda",
    "message-logging",
    "chatbot"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "crypto": "^1.0.1",
    "moment-timezone": "^0.5.43"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "serverless": "^3.38.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-offline": "^13.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
